{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Pi Desktop",
  "version": "0.1.0",
  "identifier": "dev.pidesktop.app",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "frontendDist": "../../ui/dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Pi Desktop",
        "width": 1240,
        "height": 840,
        "minWidth": 800,
        "minHeight": 560,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.png",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/pi-host"
    ]
  }
}